# Required: Discord webhook URL for notifications when the product is back in stock.
# Create one: Discord channel -> Server Settings -> Integrations -> Webhooks -> New Webhook -> Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Optional: How often to check the product page (in minutes). Default: 5
# CHECK_INTERVAL_MINUTES=5

# Optional: Product URL. Default: BTS Light Stick Ver.4 on Weverse Shop (USD)
# PRODUCT_URL=https://shop.weverse.io/en/shop/USD/artists/2/sales/54189
